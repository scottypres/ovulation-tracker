# Baserow (self-hosted)
BASEROW_BASE_URL=https://baserow.serenadesongs.com
BASEROW_DATABASE_ID=283
BASEROW_API_TOKEN=

# Auth — signed cookie secret (any long random string, rotate to invalidate sessions)
SESSION_SECRET=

# Vercel Cron — protects /api/cron/* routes
CRON_SECRET=

# Pushover (Phase 5)
PUSHOVER_TOKEN=
PUSHOVER_USER=

# App timezone — used by the daily cron to compute "today" in her local time
APP_TIMEZONE=America/New_York
